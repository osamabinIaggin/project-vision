# ----------------------------------------------------------------------------
# Geospatial binary artefacts — excluded by policy.
# These are deterministically reproducible from the acquisition scripts in
# scripts/ and routinely exceed the platform's per-blob size ceiling. The
# repository versions the methodology, not the raster payload.
# ----------------------------------------------------------------------------
*.tif
*.tiff
*.tif.aux.xml
*.tif.ovr
*.osm
*.osm.pbf
*.gpkg
*.gpkg-wal
*.gpkg-shm

# Derived intermediates and scratch outputs
/accra_flood/output/
/scratch/
*.png
# Curated figures are retained deliberately (negation must be on its own line;
# gitignore does not support trailing inline comments on pattern lines).
!docs/figures/*.png
# GDAL raster sidecars are never versioned
*.msk
*.aux.xml

# Operating-system and editor detritus
.DS_Store
.ipynb_checkpoints/
__pycache__/
*.pyc
.venv/
venv/
